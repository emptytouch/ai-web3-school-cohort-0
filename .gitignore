# ============================================
# Git Ignore — ai-web3-school-cohort-0
# ============================================

# --- 环境变量 / 密钥 ---
.env
.env.local
.env.*.local
*.key
*.pem
*.secret
*.credentials

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# --- IDE / 编辑器 ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- 系统文件 ---
*.log
*.tmp
*.bak
core
core.*

# --- 大文件 / 二进制 ---
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.mp4
*.mp3
*.avi
*.mov
*.pdf
*.iso
*.img

# --- 数据文件（按需调整） ---
*.csv
*.db
*.sqlite
*.sqlite3

# --- 临时文件 ---
.cache/
tmp/
temp/
